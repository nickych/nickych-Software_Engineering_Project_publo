generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String?
  email    String  @unique
  password String
  role     String
  // Remove announcements here if User no longer posts announcements
}

model Lecturer {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  role          String         @default("lecturer")
  announcements Announcement[] @relation("LecturerAnnouncements")
}

model Admin {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     String @default("admin") // optional but recommended
}


model Announcement {
  id         Int      @id @default(autoincrement())
  title      String
  content    String
  createdAt  DateTime @default(now())
  lecturer   Lecturer @relation("LecturerAnnouncements", fields: [lecturerId], references: [id])
  lecturerId Int
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  course      String
  semester    String   // ✅ FIX HERE
  fileUrl     String
  lecturerId  Int
  createdAt   DateTime @default(now())
}