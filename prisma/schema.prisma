generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int      @id @default(autoincrement())
  name            String?
  email           String   @unique
  password        String
  role            String
  courseId        Int?
  profileImage    String?
  profileImageUrl String?
  createdAt       DateTime @default(now())
  results         Result[]
  Course          Course?  @relation(fields: [courseId], references: [id])
}

model Lecturer {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  role          String         @default("lecturer")
  announcements Announcement[] @relation("LecturerAnnouncements")
}

model Admin {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     String @default("admin")
}

model Announcement {
  id         Int      @id @default(autoincrement())
  title      String
  content    String
  lecturerId Int
  createdAt  DateTime @default(now())
  lecturer   Lecturer @relation("LecturerAnnouncements", fields: [lecturerId], references: [id])
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  course      String
  semester    String
  fileUrl     String
  lecturerId  Int
  createdAt   DateTime @default(now())
}

model AssignmentSubmission {
  id          Int      @id @default(autoincrement())
  title       String
  studentId   String
  fileUrl     String
  fileName    String
  grade       String?
  feedback    String?
  submittedAt DateTime @default(now())
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  studentId String
  fileUrl   String
  createdAt DateTime @default(now())
}

model Result {
  id           Int      @id @default(autoincrement())
  studentEmail String
  module       String
  year         String
  semester     String
  cat1         Float?
  cat2         Float?
  finalExam    Float?
  total        Float?
  grade        String?
  status       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  student      User     @relation(fields: [studentEmail], references: [email], onDelete: Cascade)

  @@unique([studentEmail, module, semester])
}

model Module {
  id        Int      @id @default(autoincrement())
  name      String
  year      String
  semester  String
  createdAt DateTime @default(now())
}

model Course {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  User      User[]
}
